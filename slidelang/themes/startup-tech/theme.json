{
  "author": "SlideLang Dev",
  "description": "Startup tech theme with solid colors - vibrant purple and electric green for clean tech presentations with CSS namespacing support",
  "name": "startup-tech",
  "variables": {
    "--slidelang-primary-color": "#8b5cf6",
    "--slidelang-secondary-color": "#0f172a", 
    "--slidelang-accent-color": "#06ffa5",
    "--slidelang-success-color": "#06ffa5",
    "--slidelang-warning-color": "#fbbf24",
    "--slidelang-danger-color": "#f43f5e",
    "--slidelang-info-color": "#06b6d4",
    "--slidelang-tip-color": "#a855f7",

    "--slidelang-gradient-bg": "#8b5cf6",
    "--slidelang-title-gradient": "#0f172a",
    "--slidelang-accent-gradient": "#06ffa5",

    "--slidelang-font-main": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "--slidelang-font-code": "'JetBrains Mono', 'Fira Code', 'SF Mono', Consolas, monospace",
    "--slidelang-font-heading": "'Inter', -apple-system, BlinkMacSystemFont, sans-serif",

    "--slidelang-border-radius": "0.5rem",
    "--slidelang-border-radius-lg": "1rem",
    "--slidelang-border-radius-sm": "0.25rem",

    "--slidelang-shadow-main": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
