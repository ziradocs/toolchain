    "--slidelang-border-copy-button": "rgba(139, 92, 246, 0.3)",
    "--slidelang-bg-copy-button-hover": "rgba(139, 92, 246, 0.25)",
    "--slidelang-bg-line-highlight": "rgba(6, 255, 165, 0.1)",
    "--slidelang-bg-diff-added": "rgba(6, 255, 165, 0.15)",
    "--slidelang-bg-diff-removed": "rgba(244, 63, 94, 0.15)",
    "--slidelang-bg-image-overlay": "rgba(15, 23, 42, 0.7)",
    "--slidelang-bg-comparison-label": "rgba(15, 23, 42, 0.9)",
