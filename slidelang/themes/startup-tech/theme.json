    "--slidelang-bg-danger-light": "#fef2f2",
    "--slidelang-bg-info-light": "#eff6ff",
    "--slidelang-bg-placeholder": "rgba(139, 92, 246, 0.05)",

    "--slidelang-border-color": "#e2e8f0",

    "--slidelang-note-color": "#64748b",
    "--slidelang-note-text-color": "#334155",
    "--slidelang-details-border-color": "#d1d5db",
    "--slidelang-details-text-color": "#374151",
    "--slidelang-success-text-color": "#065f46",
    "--slidelang-warning-text-color": "#92400e",
    "--slidelang-danger-text-color": "#991b1b",
    "--slidelang-info-text-color": "#1e40af",

    "--slidelang-highlight-bg": "#fbbf24",
    "--slidelang-highlight-text": "#713f12",

    "--slidelang-link-color": "#8b5cf6",
    "--slidelang-link-bg": "rgba(139, 92, 246, 0.05)",
