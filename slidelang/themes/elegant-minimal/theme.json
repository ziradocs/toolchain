{
  "name": "elegant-minimal",
  "description": "Sophisticated minimalist theme with premium typography, subtle animations, and luxurious spacing. Features Japanese-inspired design principles with perfect contrast ratios and editorial-quality layouts.",
  "author": "SlideLang Design Team", 
  "version": "1.0.0",
  "variables": {
    "--slidelang-primary-color": "#000000",
    "--slidelang-secondary-color": "#2d2d2d",
    "--slidelang-accent-color": "#c9a961",
    "--slidelang-success-color": "#2d5016",
    "--slidelang-warning-color": "#8b4513",
    "--slidelang-danger-color": "#8b0000",
    "--slidelang-info-color": "#1e3a5f",
    "--slidelang-tip-color": "#4a4a4a",

    "--slidelang-gradient-bg": "linear-gradient(180deg, #ffffff 0%, #fafafa 100%)",
    "--slidelang-title-gradient": "linear-gradient(135deg, #000000 0%, #2d2d2d 100%)",
    "--slidelang-accent-gradient": "linear-gradient(135deg, #c9a961 0%, #ddbf77 100%)",

    "--slidelang-font-main": "'Crimson Text', 'Times New Roman', serif",
    "--slidelang-font-code": "'Berkeley Mono', 'SF Mono', 'Monaco', monospace",
    "--slidelang-font-heading": "'Playfair Display', 'Georgia', serif",

    "--slidelang-border-radius": "0rem",
    "--slidelang-border-radius-lg": "0rem",
    "--slidelang-border-radius-sm": "0rem",
    "--slidelang-border-color": "#e8e8e8",

    "--slidelang-shadow-main": "none",
    "--slidelang-shadow-lg": "0 1px 2px rgba(0, 0, 0, 0.05)",
    "--slidelang-shadow-xl": "0 2px 4px rgba(0, 0, 0, 0.08)",
    "--slidelang-shadow-text": "none",
    "--slidelang-shadow-light": "none",
    "--slidelang-shadow-medium": "0 1px 1px rgba(0, 0, 0, 0.03)",

    "--slidelang-transition": "all 0.6s cubic-bezier(0.19, 1, 0.22, 1)",
    "--slidelang-transition-fast": "all 0.3s cubic-bezier(0.19, 1, 0.22, 1)",

    "--slidelang-text-color": "#1a1a1a",
    "--slidelang-text-light": "#666666",
    "--slidelang-text-muted": "#999999",
    "--slidelang-text-on-primary": "#ffffff",
    "--slidelang-text-on-accent": "#ffffff",
    "--slidelang-text-on-dark": "#ffffff",

    "--slidelang-bg-white": "#ffffff",
    "--slidelang-background-color": "#ffffff",
    "--slidelang-bg-gray-50": "#fafafa",
    "--slidelang-bg-gray-100": "#f5f5f5",
    "--slidelang-bg-code": "#f8f8f8",
    "--slidelang-bg-light": "#fefefe",

    "--slidelang-bg-info": "#f8f9fa",
    "--slidelang-bg-success": "#f1f8e9",
    "--slidelang-bg-warning": "#fff8e1",
    "--slidelang-bg-danger": "#ffebee",
    "--slidelang-bg-tip": "#f5f5f5",

    "--slidelang-bg-note": "#f9f9f9",
    "--slidelang-bg-success-light": "#f1f8e9",
    "--slidelang-bg-warning-light": "#fff8e1",
    "--slidelang-bg-danger-light": "#ffebee",
    "--slidelang-bg-info-light": "#f8f9fa",
    "--slidelang-bg-placeholder": "#f5f5f5",

    "--slidelang-note-color": "#666666",
    "--slidelang-note-text-color": "#1a1a1a",
    "--slidelang-details-border-color": "#e8e8e8",
    "--slidelang-details-text-color": "#1a1a1a",
    "--slidelang-success-text-color": "#2d5016",
    "--slidelang-warning-text-color": "#8b4513",
    "--slidelang-danger-text-color": "#8b0000",
    "--slidelang-info-text-color": "#1e3a5f",

    "--slidelang-highlight-bg": "#ffffcc",
    "--slidelang-highlight-text": "#1a1a1a",

    "--slidelang-link-color": "#c9a961",
    "--slidelang-link-bg": "transparent",
    "--slidelang-link-hover-color": "#000000",
    "--slidelang-link-hover-bg": "transparent",

    "--slidelang-bg-title-slide": "linear-gradient(135deg, #1a1a1a 0%, #000000 100%)",
    "--slidelang-bg-section-slide": "#fafafa",
    "--slidelang-bg-content-slide": "#ffffff",
    "--slidelang-bg-end-slide": "linear-gradient(135deg, #c9a961 0%, #ddbf77 100%)",
    "--slidelang-bg-closing-slide": "#1a1a1a",

    "--slidelang-syntax-comment": "#999999",
    "--slidelang-syntax-keyword": "#000000",
    "--slidelang-syntax-string": "#2d5016",
    "--slidelang-syntax-number": "#8b4513",
    "--slidelang-syntax-operator": "#666666",
    "--slidelang-syntax-function": "#1e3a5f",
    "--slidelang-syntax-variable": "#4a4a4a",
    "--slidelang-syntax-type": "#c9a961",

    "--slidelang-bg-quote": "#f9f9f9",
    "--slidelang-bg-hover": "#f5f5f5",
    "--slidelang-bg-progress": "#e8e8e8",
    "--slidelang-bg-copy-button": "#f5f5f5",
    "--slidelang-border-copy-button": "#e8e8e8",
    "--slidelang-bg-copy-button-hover": "#eeeeee",
    "--slidelang-bg-line-highlight": "#f1f8e9",
    "--slidelang-bg-diff-added": "#e8f5e8",
    "--slidelang-bg-diff-removed": "#ffeaea",
    "--slidelang-bg-image-overlay": "rgba(26, 26, 26, 0.8)",
    "--slidelang-bg-comparison-label": "rgba(255, 255, 255, 0.95)",
    "--slidelang-bg-lightbox": "rgba(26, 26, 26, 0.95)"
  }
}
