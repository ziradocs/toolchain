{
  "name": "cyberpunk-neon",
  "description": "Futuristic cyberpunk theme with neon glows, electric colors, and high-tech aesthetics. Features animated gradients, holographic effects, and terminal-inspired layouts perfect for tech presentations.",
  "author": "SlideLang Design Team",
  "version": "1.0.0",
  "variables": {
    "--slidelang-primary-color": "#00ffff",
    "--slidelang-secondary-color": "#ff006e",
    "--slidelang-accent-color": "#8338ec",
    "--slidelang-success-color": "#00f5ff",
    "--slidelang-warning-color": "#ffbe0b",
    "--slidelang-danger-color": "#ff006e",
    "--slidelang-info-color": "#00ffff",
    "--slidelang-tip-color": "#c77dff",

    "--slidelang-gradient-bg": "linear-gradient(135deg, #0a0a0a 0%, #1a0033 25%, #000a1a 50%, #001a33 75%, #0a0a0a 100%)",
    "--slidelang-title-gradient": "linear-gradient(135deg, #ff006e 0%, #8338ec 25%, #3a86ff 50%, #00ffff 75%, #00f5ff 100%)",
    "--slidelang-accent-gradient": "linear-gradient(135deg, #00ffff 0%, #00f5ff 25%, #3a86ff 50%, #8338ec 75%, #c77dff 100%)",

    "--slidelang-font-main": "'JetBrains Mono', 'Fira Code', 'SF Mono', 'Consolas', monospace",
    "--slidelang-font-code": "'JetBrains Mono', 'Source Code Pro', 'SF Mono', monospace",
    "--slidelang-font-heading": "'Orbitron', 'JetBrains Mono', monospace",

    "--slidelang-border-radius": "0.25rem",
    "--slidelang-border-radius-lg": "0.5rem",
    "--slidelang-border-radius-sm": "0.125rem",
    "--slidelang-border-color": "#00ffff",

    "--slidelang-shadow-main": "0 0 20px rgba(0, 255, 255, 0.5), 0 0 40px rgba(0, 255, 255, 0.3), 0 4px 8px rgba(0, 0, 0, 0.8)",
    "--slidelang-shadow-lg": "0 0 40px rgba(255, 0, 110, 0.6), 0 0 80px rgba(255, 0, 110, 0.4), 0 10px 20px rgba(0, 0, 0, 0.9)",
    "--slidelang-shadow-xl": "0 0 60px rgba(131, 56, 236, 0.7), 0 0 120px rgba(131, 56, 236, 0.5), 0 20px 40px rgba(0, 0, 0, 0.95)",
    "--slidelang-shadow-text": "0 0 10px currentColor, 0 2px 4px rgba(0, 0, 0, 0.8)",
    "--slidelang-shadow-light": "0 0 10px rgba(0, 255, 255, 0.3)",
    "--slidelang-shadow-medium": "0 0 20px rgba(0, 255, 255, 0.4), 0 2px 4px rgba(0, 0, 0, 0.6)",

    "--slidelang-transition": "all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94)",
    "--slidelang-transition-fast": "all 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94)",

    "--slidelang-text-color": "#e0e0e0",
    "--slidelang-text-light": "#b0b0b0",
    "--slidelang-text-muted": "#808080",
    "--slidelang-text-on-primary": "#000000",
    "--slidelang-text-on-accent": "#000000",
    "--slidelang-text-on-dark": "#00ffff",

    "--slidelang-bg-white": "#0a0a0a",
    "--slidelang-background-color": "radial-gradient(circle at 50% 50%, #1a0033 0%, #000a1a 50%, #000000 100%)",
    "--slidelang-bg-gray-50": "#1a1a1a",
    "--slidelang-bg-gray-100": "#2a2a2a",
    "--slidelang-bg-code": "#000000",
    "--slidelang-bg-light": "#1a1a1a",

    "--slidelang-bg-info": "rgba(0, 255, 255, 0.1)",
    "--slidelang-bg-success": "rgba(0, 245, 255, 0.1)",
    "--slidelang-bg-warning": "rgba(255, 190, 11, 0.1)",
    "--slidelang-bg-danger": "rgba(255, 0, 110, 0.1)",
    "--slidelang-bg-tip": "rgba(199, 125, 255, 0.1)",

    "--slidelang-bg-note": "rgba(0, 255, 255, 0.05)",
    "--slidelang-bg-success-light": "rgba(0, 245, 255, 0.05)",
    "--slidelang-bg-warning-light": "rgba(255, 190, 11, 0.05)",
    "--slidelang-bg-danger-light": "rgba(255, 0, 110, 0.05)",
    "--slidelang-bg-info-light": "rgba(0, 255, 255, 0.05)",
    "--slidelang-bg-placeholder": "rgba(0, 255, 255, 0.08)",

    "--slidelang-note-color": "#00ffff",
    "--slidelang-note-text-color": "#e0e0e0",
    "--slidelang-details-border-color": "#00ffff",
    "--slidelang-details-text-color": "#e0e0e0",
    "--slidelang-success-text-color": "#00f5ff",
    "--slidelang-warning-text-color": "#ffbe0b",
    "--slidelang-danger-text-color": "#ff006e",
    "--slidelang-info-text-color": "#00ffff",

    "--slidelang-highlight-bg": "rgba(255, 0, 110, 0.3)",
    "--slidelang-highlight-text": "#ffffff",

    "--slidelang-link-color": "#00ffff",
    "--slidelang-link-bg": "rgba(0, 255, 255, 0.1)",
    "--slidelang-link-hover-color": "#00f5ff",
    "--slidelang-link-hover-bg": "rgba(0, 255, 255, 0.2)",

    "--slidelang-bg-title-slide": "linear-gradient(135deg, #000000 0%, #1a0033 25%, #000a1a 50%, #001a33 75%, #0a0a0a 100%), repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(0, 255, 255, 0.03) 2px, rgba(0, 255, 255, 0.03) 4px)",
    "--slidelang-bg-section-slide": "linear-gradient(135deg, #0a0a0a 0%, #1a0033 50%, #000a1a 100%)",
    "--slidelang-bg-content-slide": "radial-gradient(circle at 20% 50%, rgba(26, 0, 51, 0.3) 0%, transparent 50%), radial-gradient(circle at 80% 50%, rgba(0, 10, 26, 0.3) 0%, transparent 50%), #000000",
    "--slidelang-bg-end-slide": "linear-gradient(135deg, #ff006e 0%, #8338ec 25%, #3a86ff 50%, #00ffff 75%, #00f5ff 100%)",
    "--slidelang-bg-closing-slide": "linear-gradient(135deg, #8338ec 0%, #c77dff 50%, #ff006e 100%)",

    "--slidelang-syntax-comment": "#808080",
    "--slidelang-syntax-keyword": "#ff006e",
    "--slidelang-syntax-string": "#00ffff",
    "--slidelang-syntax-number": "#ffbe0b",
    "--slidelang-syntax-operator": "#8338ec",
    "--slidelang-syntax-function": "#00f5ff",
    "--slidelang-syntax-variable": "#c77dff",
    "--slidelang-syntax-type": "#3a86ff",

    "--slidelang-bg-quote": "rgba(0, 255, 255, 0.08)",
    "--slidelang-bg-hover": "rgba(0, 255, 255, 0.1)",
    "--slidelang-bg-progress": "rgba(0, 255, 255, 0.2)",
    "--slidelang-bg-copy-button": "rgba(0, 255, 255, 0.15)",
    "--slidelang-border-copy-button": "#00ffff",
    "--slidelang-bg-copy-button-hover": "rgba(0, 255, 255, 0.25)",
    "--slidelang-bg-line-highlight": "rgba(0, 245, 255, 0.1)",
    "--slidelang-bg-diff-added": "rgba(0, 245, 255, 0.15)",
    "--slidelang-bg-diff-removed": "rgba(255, 0, 110, 0.15)",
    "--slidelang-bg-image-overlay": "rgba(0, 0, 0, 0.8)",
    "--slidelang-bg-comparison-label": "rgba(0, 255, 255, 0.9)",
    "--slidelang-bg-lightbox": "rgba(0, 0, 0, 0.95)"
  }
}
