{
  "name": "doclang-vscode",
  "displayName": "DocLang Preview",
  "description": "Real-time preview for DocLang markdown documents",
  "version": "0.1.0",
  "publisher": "ziradocs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ziradocs/toolchain",
    "directory": "doclang-vscode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "markdown",
    "preview",
    "doclang",
    "documentation",
    "live preview"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "doclang.preview",
        "title": "DocLang: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "doclang.previewToSide",
        "title": "DocLang: Open Preview to the Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "doclang.refreshPreview",
        "title": "DocLang: Refresh Preview",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "doclang.previewToSide",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "doclang.preview",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "doclang.preview",
          "when": "resourceLangId == markdown"
        },
        {
          "command": "doclang.previewToSide",
          "when": "resourceLangId == markdown"
        },
        {
          "command": "doclang.refreshPreview"
        }
      ]
    },
    "configuration": {
      "title": "DocLang",
      "properties": {
        "doclang.executablePath": {
          "type": "string",
          "default": "doclang",
          "description": "Path to the DocLang CLI executable"
        },
        "doclang.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh preview on file save"
        },
        "doclang.tocEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable table of contents in preview"
        },
        "doclang.previewColumn": {
          "type": "string",
          "default": "beside",
          "enum": ["beside", "active"],
          "description": "Where to open the preview"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "@vscode/test-electron": "^2.3.4",
    "eslint": "^8.47.0",
    "glob": "^10.3.3",
    "mocha": "^10.2.0",
    "ts-loader": "^9.4.4",
    "typescript": "^5.1.6",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  }
}
