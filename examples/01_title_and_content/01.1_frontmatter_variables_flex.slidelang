## Tools and Automation

### Validation Script

```bash
#!/bin/bash
# validate-frontmatter.sh

echo "Validating frontmatter in .slidelang files..."

for file in *.slidelang; do
  echo "Checking: $file"

  # Extract frontmatter (between the first two --- lines)
  frontmatter=$(sed -n '/^---$/,/^---$/p' "$file" | sed '1d;$d')

  # Validate YAML
  echo "$frontmatter" | python -c "
import yaml, sys
try:
    yaml.safe_load(sys.stdin.read())
    print('  ✅ Valid YAML')
except yaml.YAMLError as e:
    print('  ❌ YAML Error:', e)
    exit(1)
"
done

echo "Validation complete ✅"
```

### Template Generator

```python
# template_generator.py
import yaml
from datetime import datetime

def generate_presentation_template(config):
    """Generates a presentation template with variables"""

    frontmatter = {
        'mode': 'flex',
        'title': config['title'],
        'author': config['author'],
        'date': datetime.now().strftime('%Y-%m-%d'),
        'theme': config.get('theme', 'modern-blue'),
        'variables': config['variables']
    }

    yaml_content = yaml.dump(frontmatter, default_flow_style=False)

    template = f"""---
{yaml_content}---

# {config['title']}
## {config.get('subtitle', 'Subtitle placeholder')}

*Automatically generated on {datetime.now().strftime('%Y-%m-%d')}*

---

## Main Content

Your content here...

Available variables:
{chr(10).join([f'- {k}: {{{{{k}}}}}' for k in config['variables'].keys()])}
"""

    return template

# Usage
config = {
    'title': 'My New Presentation',
    'subtitle': 'Descriptive subtitle',
    'author': 'My Name',
    'theme': 'corporate',
    'variables': {
        'product_name': 'My Product',
        'version': 'v1.0',
        'company': 'My Company'
    }
}

template = generate_presentation_template(config)
print(template)
```

