# Code Blocks

## JavaScript Code

```javascript
// Function to calculate factorial
function factorial(n) {
    if (n === 0 || n === 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

// Usage example
const number = 5;
const result = factorial(number);
console.log(`The factorial of ${number} is ${result}`);
```

## Python Code

```python
# Class for user management
class UserManager:
    def __init__(self):
        self.users = []

    def add_user(self, name, email):
        """Add a new user"""
        user = {
            'name': name,
            'email': email,
            'active': True
        }
        self.users.append(user)
        return user

    def get_active_users(self):
        """Get active users"""
        return [u for u in self.users if u['active']]

# Usage
manager = UserManager()
manager.add_user("Ana Garcia", "ana@example.com")
print(f"Active users: {len(manager.get_active_users())}")
```

## SQL Code

```sql
-- Sales analysis query
SELECT
    p.product_name,
    c.category_name,
    SUM(oi.quantity) as total_sold,
    SUM(oi.quantity * oi.unit_price) as revenue,
    AVG(oi.unit_price) as avg_price
FROM
    orders o
    JOIN order_items oi ON o.order_id = oi.order_id
    JOIN products p ON oi.product_id = p.product_id
    JOIN categories c ON p.category_id = c.category_id
WHERE
    o.order_date BETWEEN '2025-01-01' AND '2025-12-31'
    AND o.status = 'completed'
GROUP BY
    p.product_name, c.category_name
HAVING
    SUM(oi.quantity) > 100
ORDER BY
    revenue DESC
LIMIT 10;
```

## Go Code

```go
package main

import (
    "fmt"
    "time"
)

// Server represents a web server
type Server struct {
    Host string
    Port int
    StartTime time.Time
}

// NewServer creates a new server instance
func NewServer(host string, port int) *Server {
    return &Server{
        Host: host,
        Port: port,
        StartTime: time.Now(),
    }
}

// Start starts the server
func (s *Server) Start() error {
    fmt.Printf("Server starting on %s:%d\n", s.Host, s.Port)
    // Server implementation...
    return nil
}

func main() {
    server := NewServer("localhost", 8080)
    if err := server.Start(); err != nil {
        fmt.Printf("Error: %v\n", err)
    }
}
```

