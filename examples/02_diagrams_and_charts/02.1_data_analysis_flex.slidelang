    responsive: true
    plugins:
      title:
        display: true
        text: "Segmentation by Annual Customer Value"
      legend:
        position: right
      tooltip:
        callbacks:
          label: "function(context) { 
            const total = context.dataset.data.reduce((a, b) => a + b, 0);
            const percentage = Math.round((context.parsed / total) * 100);
            return context.label + ': ' + percentage + '%';
          }"
    cutout: "60%"

