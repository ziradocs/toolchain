## Map with Custom Dimensions (1400x700)

<<map width="1400" height="700">>
  type: region
  center: [39.8283, -98.5795]
  zoom: 4
  markers:
    - lat: 37.7749
      lng: -122.4194
      label: "San Francisco"
      color: "#2196F3"
      size: "large"
    - lat: 40.7128
      lng: -74.0060
      label: "New York"
      color: "#4CAF50"
      size: "large"
    - lat: 41.8781
      lng: -87.6298
