mode: flex
title: "Advanced Configuration - Headers and Footers"
author: "Dr. Maria Gonzalez"
company: "TechCorp Solutions"
department: "Digital Innovation"
project: "Corporate Presentation"
date: "December 27, 2024"
quarter: "Q4 2024"
theme: "corporate-advanced"

# Complete header with logo and text
header:
  enabled: true
  logo:
    source: "./assets/techcorp-logo.png"
    alt: "TechCorp Solutions"
    position: "left"
    height: "40px"
    link: "https://techcorp.com"
  text:
    position: "right"
    content: "{{department}} • {{quarter}}"
    style: "subtitle"
    color: "#666666"
    font_size: "14px"
  divider: true

# Complete footer with page numbers and text
footer:
  enabled: true
  page_numbers:
    enabled: true
    format: "{{current}} / {{total}}"
    position: "right"
    exclude_title_slides: true
    exclude_section_slides: false
    start_from: 2
    style: "caption"
    prefix: "Page "
  text:
    left: "© 2024 {{company}}"
    center: "{{project}}"
    right: ""
  social_links:
    - platform: "website"
      url: "techcorp.com"
      position: "left"
    - platform: "email"
      url: "contacto@techcorp.com"
      position: "left"
  divider: true

# Custom variables
variables:
  status: "Confidential"
  version: "v2.1"
  team: "Team Alpha"
  budget: "$2.5M"

# Layout-specific configuration
layout_defaults:
  title:
    header:
      enabled: false
    footer:
      enabled: false

  title_slide:
    header:
      enabled: true
      text:
        content: "{{department}} • New Section"
    footer:
      page_numbers:
        enabled: false
      text:
        center: ""

  section:
    header:
      text:
        content: "{{department}} • {{project}}"
        color: "#2c5282"
    footer:
      page_numbers:
        format: "Section {{current}}"
      text:
        left: "{{status}} - {{team}}"

  stats:
    footer:
      text:
        left: "Data updated: {{date}}"
        center: "Budget: {{budget}}"

  comparison:
    header:
      text:
        content: "Competitive Analysis • {{department}}"
    footer:
      text:
        left: "{{status}} Evaluation"

  closing:
    header:
      enabled: true
      logo:
        height: "50px"
    footer:
      page_numbers:
        enabled: false
      text:
        left: "{{company}}"
        center: "Thank you for your attention"
        right: ""
      social_links: []
---

