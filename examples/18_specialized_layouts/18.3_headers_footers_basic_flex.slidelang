---
mode: flex
title: "Basic Example - Headers and Footers"
author: "slidelang Team"
company: "slidelang Inc."
date: "December 27, 2024"
theme: "corporate"

# Basic configuration - Page numbers only
header:
  enabled: false

footer:
  enabled: true
  page_numbers:
    enabled: true
    format: "{{current}} / {{total}}"
    position: "right"
    exclude_title_slides: true
    start_from: 2
    style: "caption"
  text:
    left: ""
    center: ""
    right: ""

# Per-layout configuration
layout_defaults:
  title:
    footer:
      enabled: false  # No footer on the cover slide
  closing:
    footer:
      page_numbers:
        enabled: false  # No numbers on the final slide
---

---
layout: title
---

